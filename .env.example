# ─── Cấu hình Cơ bản ────────────────────────────────────────────────────────
# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key

# ─── Cổng Thanh Toán ──────────────────────────────────────────────────────
# Stripe (Thẻ tín dụng)
STRIPE_SECRET_KEY=sk_test_..._your_stripe_key

# SePay (Chuyển khoản ngân hàng)
SEPAY_ENV=sandbox
SEPAY_MERCHANT_ID=your_merchant_id
SEPAY_SECRET_KEY=your_secret_key
SEPAY_RETURN_URL=http://localhost:3000/checkout/success
SEPAY_IPN_URL=http://localhost:8080/api/orders/webhook/sepay

# ─── Tiện ích Khác ────────────────────────────────────────────────────────
# Ngrok (Dùng để test Webhook Local)
NGROK_AUTHTOKEN=your_ngrok_auth_token

# Email (SMTP Gmail)
SMTP_EMAIL=your_email@gmail.com
SMTP_PASS=your_app_password
